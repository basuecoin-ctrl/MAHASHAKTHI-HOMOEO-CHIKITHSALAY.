<!DOCTYPE html>
<html>
<head>
<title>Mahashakthi homoeo CHIKITHSALAY Form</title>

<style>
body{
font-family: Arial;
padding:20px;
}

input, textarea, select{
width:100%;
padding:8px;
margin:5px 0;
}

button{
padding:10px 20px;
margin-top:10px;
}

h2{
color:darkgreen;
}
</style>

</head>

<body>

<h2>Homoeopathy Online Case Taking Form</h2>

<form>

<label>Patient Name</label>
<input type="text" placeholder="Enter name">

<label>Age</label>
<input type="number">

<label>Gender</label>
<select>
<option>Male</option>
<option>Female</option>
<option>Other</option>
</select>

<label>Mobile Number</label>
<input type="text">

<label>Address</label>
<textarea></textarea>

<h3>Main Complaint</h3>

<label>Main Problem</label>
<textarea placeholder="Describe main disease/problem"></textarea>

<label>Since When</label>
<input type="text" placeholder="Example: 2 years">

<label>What makes it worse?</label>
<textarea></textarea>

<label>What makes it better?</label>
<textarea></textarea>

<h3>Past History</h3>

<label>Previous Diseases</label>
<textarea placeholder="Diabetes, BP etc"></textarea>

<label>Family History</label>
<textarea></textarea>

<h3>General Symptoms</h3>

<label>Appetite</label>
<select>
<option>Normal</option>
<option>Low</option>
<option>High</option>
</select>

<label>Thirst</label>
<select>
<option>Less</option>
<option>Normal</option>
<option>More</option>
</select>

<label>Sleep</label>
<select>
<option>Good</option>
<option>Disturbed</option>
<option>Insomnia</option>
</select>

<label>Food Desire</label>
<input type="text" placeholder="Sweet, Sour, Salt etc">

<label>Food Aversion</label>
<input type="text">

<h3>Mental Symptoms</h3>

<label>Mental State</label>
<textarea placeholder="Anger, Fear, Anxiety etc"></textarea>

<label>Stress / Worry</label>
<textarea></textarea>

<br>

<button type="submit">Submit Case</button>

</form>

</body>
</html>
